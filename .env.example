# ============================================
# H-Sport - Environment Variables Example
# ============================================
# Скопируйте в .env и заполните реальными значениями.
# Для production см. docs/DEPLOYMENT.md или DEPLOY_COMMANDS.md (шаг 21).

# REQUIRED
DATABASE_URL="postgresql://user:password@localhost:5432/hsport?schema=public"
NODE_ENV="development"

# RECOMMENDED
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="your-auth-secret-minimum-32-characters-long"
AUTH_URL="http://localhost:3000"

# EMAIL (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="h-sport <noreply@example.com>"

# CDEK API (тестовые: Account = CLIENT_ID, Secure password = CLIENT_SECRET, api.edu.cdek.ru)
CDEK_CLIENT_ID="your-cdek-client-id"
CDEK_CLIENT_SECRET="your-cdek-client-secret"
CDEK_IS_TEST="true"
CDEK_FROM_CITY_CODE="137"

# DaData API
DADATA_TOKEN="your-dadata-api-token"

# ROBOKASSA
ROBOKASSA_MERCHANT_LOGIN=""
ROBOKASSA_PASSWORD_1=""
ROBOKASSA_PASSWORD_2=""
ROBOKASSA_IS_TEST="true"
ROBOKASSA_HASH_ALGORITHM="sha256"

# ADMIN
# Email привилегированного администратора (получает ADMIN-роль автоматически)
ADMIN_EMAIL="jaksan37@gmail.com"

# ALERTS
# ALERT_EMAIL="alerts@example.com"
# ALERT_WEBHOOK_URL="https://hooks.slack.com/services/..."

# POSTCALC (тарифы Почты России)
# POSTCALC_FROM_CITY="Москва"
# POSTCALC_KEY="your-postcalc-key"

# DATABASE TUNING (при деплое: раскомментировать при необходимости)
# Пул соединений к БД. Для production обычно 10–15. Таймаут ожидания соединения из пула (мс).
# DB_POOL_MAX="10"
# DB_POOL_TIMEOUT_MS="5000"

# DELIVERY (при деплое: раскомментировать и указать сумму в копейках)
# Минимальная плата за доставку в копейках, например 50000 = 500 руб.
# DELIVERY_FEE_KOPECKS="50000"

# CACHE (in-memory, при деплое обычно не трогать)
# Таймаут loader'а в getOrSetAsync (мс). Допустимый диапазон 1000..60000 (проверяется в validate-config).
# CACHE_LOADER_TIMEOUT_MS=15000
# CACHE_DEBUG="false"

# LOGGING
LOG_LEVEL="info"
PRISMA_LOG_QUERIES="false"
ENABLE_FILE_LOGGING=true
# SLOW_QUERY_LOGGING="true"
# SLOW_QUERY_THRESHOLD_MS="1000"

# SECURITY (CORS and HTTP Headers)
# В production укажите реальные домены. NEVER use ALLOW_ANY_ORIGIN=true in production!
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# ALLOW_ANY_ORIGIN="true"  # только для локальной разработки; в production не задавать или false

SKIP_INTEGRATION_TESTS=true

ENABLE_PRODUCT_PRE_RENDER=true
