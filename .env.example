# ============================================
# H-Sport - Environment Variables Example
# ============================================
# Скопируйте в .env и заполните реальными значениями.

# REQUIRED
DATABASE_URL="postgresql://user:password@localhost:5432/hsport?schema=public"
NODE_ENV="development"

# RECOMMENDED
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_SECRET="your-auth-secret-minimum-32-characters-long"
AUTH_URL="http://localhost:3000"

# EMAIL (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="h-sport <noreply@example.com>"

# CDEK API (тестовые: Account = CLIENT_ID, Secure password = CLIENT_SECRET, api.edu.cdek.ru)
CDEK_CLIENT_ID="your-cdek-client-id"
CDEK_CLIENT_SECRET="your-cdek-client-secret"
CDEK_IS_TEST="true"
CDEK_FROM_CITY_CODE="137"

# DaData API
DADATA_TOKEN="your-dadata-api-token"

# ROBOKASSA
ROBOKASSA_MERCHANT_LOGIN=""
ROBOKASSA_PASSWORD_1=""
ROBOKASSA_PASSWORD_2=""
ROBOKASSA_IS_TEST="true"
ROBOKASSA_HASH_ALGORITHM="sha256"

# LOGGING
LOG_LEVEL="info"
PRISMA_LOG_QUERIES="false"
ENABLE_FILE_LOGGING=true

# SECURITY (CORS and HTTP Headers)
# В production укажите реальные домены. Development: ALLOW_ANY_ORIGIN=true (только для разработки!)
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
ALLOW_ANY_ORIGIN="true"

SKIP_INTEGRATION_TESTS=true

REDIS_URL=redis://localhost:6379
ENABLE_PRODUCT_PRE_RENDER=true
