# ============================================
# H-Sport - Environment Variables Example
# ============================================
# Скопируйте этот файл в .env и заполните реальными значениями.
# НИКОГДА не коммитьте .env с реальными секретами.
# cp .env.example .env

# ---------- Обязательно для production ----------
# DATABASE_URL, AUTH_SECRET (мин. 32 символа), NEXT_PUBLIC_APP_URL, REDIS_URL

# ============================================
# Database (PostgreSQL)
# ============================================
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/hsport?schema=public

# Database connection pool (опционально)
DB_POOL_MAX=10
DB_POOL_TIMEOUT_MS=5000

# Prisma query logging (опционально)
PRISMA_LOG_QUERIES=false

# ============================================
# Redis (обязателен в production для rate limit и кеша)
# ============================================
# Формат: redis://localhost:6379 или redis://user:password@host:port
REDIS_URL=redis://localhost:6379

# ============================================
# Application URLs
# ============================================
# Публичный URL приложения (для ссылок в email, sitemap и т.д.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Публичный URL API (опционально)
# NEXT_PUBLIC_API_URL=https://api.example.com

# ============================================
# Authentication & Security
# ============================================
# Секрет для JWT/сессий. Минимум 32 символа. Сгенерировать: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-minimum-32-characters-long

# AUTH_URL (опционально)
# AUTH_URL=https://auth.example.com

# ============================================
# Email (SMTP)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="H-Sport <noreply@h-brand.ru>"
SMTP_ALLOW_INSECURE_TLS=false

# ============================================
# Payment - Robokassa
# ============================================
ROBOKASSA_MERCHANT_LOGIN=your-merchant-login
ROBOKASSA_PASSWORD_1=your-password-1
ROBOKASSA_PASSWORD_2=your-password-2
ROBOKASSA_IS_TEST=true
ROBOKASSA_HASH_ALGORITHM=md5

# ============================================
# Shipping - CDEK
# ============================================
# Account из ЛК СДЭК → CDEK_CLIENT_ID, Secure password → CDEK_CLIENT_SECRET
# CDEK_IS_TEST=true — тестовый стенд api.edu.cdek.ru
CDEK_CLIENT_ID=your-cdek-client-id
CDEK_CLIENT_SECRET=your-cdek-client-secret
CDEK_IS_TEST=true
# Код города отправки в СДЭК (по умолчанию 137 = Нижний Новгород)
CDEK_FROM_CITY_CODE=137

# ============================================
# Shipping - Почта России (тарифы Postcalc.RU)
# ============================================
# Город отправки для расчёта тарифов (пробелы в запросе заменяются на _)
POSTCALC_FROM_CITY=Нижний Новгород
# Ключ API: test = 50 запросов/день с одного IP; платный ключ — в личном кабинете postcalc.ru
POSTCALC_KEY=test

# ============================================
# Shipping - DaData
# ============================================
DADATA_TOKEN=your-dadata-api-token

# ============================================
# Delivery Settings
# ============================================
DELIVERY_FEE_KOPECKS=30000

# ============================================
# CORS & Security
# ============================================
ALLOWED_ORIGINS=https://h-brand.ru
ALLOW_ANY_ORIGIN=false

# ============================================
# Logging
# ============================================
# Уровень: trace, debug, info, warn, error, fatal. В production лучше info
LOG_LEVEL=info
ENABLE_FILE_LOGGING=false
SLOW_QUERY_THRESHOLD_MS=1000

# ============================================
# Monitoring & Alerts (опционально)
# ============================================
# ALERT_EMAIL=alerts@example.com
# ALERT_WEBHOOK_URL=https://hooks.example.com/alerts

# ============================================
# Development & Build
# ============================================
NODE_ENV=development
ANALYZE=false
SKIP_INTEGRATION_TESTS=true

# Pre-render товаров при сборке (опционально)
ENABLE_PRODUCT_PRE_RENDER=false
